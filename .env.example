# ─── BACKEND (Railway) ────────────────────────────────────────────────────────

# Firebase Admin SDK credentials (paste the full JSON as a single line)
# Get this from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Firestore database ID (use "(default)" unless you created a named database)
FIRESTORE_DATABASE_ID=ai-studio-8bfbcbfe-f272-4a01-b877-aefa5ec2c4d9

# Gemini API key (for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# The Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Node environment
NODE_ENV=production

# ─── FRONTEND (Vercel) ────────────────────────────────────────────────────────
# Set these as Environment Variables in your Vercel project dashboard

# Your Railway backend URL (no trailing slash).
# Prefer VITE_* for builds from this repo. NEXT_PUBLIC_* is also supported (matches Next.js deployments).
VITE_API_URL=https://your-app.up.railway.app
NEXT_PUBLIC_API_URL=https://your-app.up.railway.app

# Firebase client SDK config (from Firebase Console → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=AIzaSyBigmk5Tib6C2Kh0yCeYgHaOmM_zQFGJag
VITE_FIREBASE_AUTH_DOMAIN=gen-lang-client-0671380675.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gen-lang-client-0671380675
VITE_FIREBASE_STORAGE_BUCKET=gen-lang-client-0671380675.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=263239506516
VITE_FIREBASE_APP_ID=1:263239506516:web:230abc94eac3509306ebc1
VITE_FIRESTORE_DATABASE_ID=ai-studio-8bfbcbfe-f272-4a01-b877-aefa5ec2c4d9
